# ═══════════════════════════════════════════════════════════════
# Realtime STT — 完整参数说明
# 这是参考文档，实际配置请直接修改 .env
# ═══════════════════════════════════════════════════════════════

# ── 模型配置 ──────────────────────────────────────────────────
# faster-whisper 支持的所有模型（从小到大）:
#   tiny, tiny.en          — ~39 MB, 最快, 精度最低
#   base, base.en          — ~74 MB
#   small, small.en        — ~244 MB
#   medium, medium.en      — ~769 MB
#   large-v1               — ~1550 MB
#   large-v2               — ~1550 MB
#   large-v3               — ~1550 MB, 精度最高
#   large-v3-turbo         — ~809 MB, 接近 large-v3 精度, 速度快 ~3x
#   distil-large-v2        — ~756 MB, 英文优化
#   distil-large-v3        — ~756 MB, 英文优化
# 注: .en 后缀模型仅支持英文, 但速度更快
MODEL_SIZE=tiny

# 推理设备: cpu / cuda / auto
DEVICE=cpu

# 计算精度: int8 (CPU推荐) / float16 (GPU推荐) / float32
COMPUTE_TYPE=int8

# ── 语言 ──────────────────────────────────────────────────────
# 留空 = 自动检测, 指定语言可提升速度和准确性
# 常用: zh, en, ja, ko, de, fr, es, pt, ru, ar
LANGUAGE=

# ── VAD (语音活动检测) ────────────────────────────────────────
VAD_BACKEND=webrtcvad
VAD_AGGRESSIVENESS=2            # 0~3, 越大越激进过滤非语音
VAD_SILENCE_THRESHOLD_MS=600    # 静音多久算一句话结束
VAD_MIN_SPEECH_MS=250           # 最短语音片段, 低于此忽略

# ── 服务器限制 ────────────────────────────────────────────────
MAX_CLIENTS=10                  # 最大并发连接数 (同时也决定推理线程池大小)
SESSION_TIMEOUT_SEC=120         # 单会话超时 (秒), 0=不限
SILENCE_TIMEOUT_SEC=10          # 持续静音断开 (秒), 0=不断开

# ── 日志 ──────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG / INFO / WARNING / ERROR
