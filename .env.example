# Model configuration
MODEL_SIZE=medium          # tiny / base / small / medium / large-v3
DEVICE=cpu                 # cpu / cuda / auto
COMPUTE_TYPE=int8          # int8 (CPU) / float16 (GPU) / float32

# Language (leave empty for auto-detect)
LANGUAGE=

# VAD settings
VAD_BACKEND=webrtcvad
VAD_AGGRESSIVENESS=2       # 0 (least) to 3 (most aggressive)
VAD_SILENCE_THRESHOLD_MS=600
VAD_MIN_SPEECH_MS=250

# Server settings
MAX_CLIENTS=10
MAX_CONNECTION_TIME=600
LOG_LEVEL=INFO
